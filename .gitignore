## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is based on the GitHub VisualStudio .gitignore template.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Vicuna (Microsoft internal)
*.Vicuna.json

# Build results
[Dd]ebug/
[Rr]elease/

# OS generated files
[Tt]humbs.db
[Ee]hthumbs.db
[Dd][Ss]_[Ss]tore

# SQLite database
*.db
*.db-shm
*.db-wal

# Environments
.env

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project-specific packages
# !**/[Pp]ackages/

# Microsoft Azure Build Output
PubTmp/
[Ss]ite[Ee]xtensions/

# Others
bin/
obj/
/publish/
